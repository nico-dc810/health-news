# Copy this file to .env on the server, then change every CHANGE_ME value.

APP_ENV=production
API_PREFIX=/api

DOMAIN=your-domain.com
ACME_EMAIL=admin@example.com

POSTGRES_DB=health_media
POSTGRES_USER=health_media
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
DATABASE_URL=postgresql+psycopg://health_media:CHANGE_ME_STRONG_DATABASE_PASSWORD@postgres:5432/health_media

SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_API_KEY=CHANGE_ME_LONG_RANDOM_ADMIN_KEY

CORS_ORIGINS=https://your-domain.com,http://your-domain.com
INTELLIGENCE_AUTO_CRAWL_ENABLED=false
INTELLIGENCE_AUTO_CRAWL_WORKSPACE_ID=demo-workspace
INTELLIGENCE_AUTO_CRAWL_INTERVAL_HOURS=24
INTELLIGENCE_AUTO_CRAWL_MAX_SOURCES=10

LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=

